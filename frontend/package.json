{
  "name": "ir2mqtt-frontend",
  "private": true,
  "version": "1.0.0-beta.3",
  "license": "MIT",
  "author": "Angelo Alvarez <steelcuts@hotmail.com>",
  "contributors": [
    "Angelo Alvarez <steelcuts@hotmail.com>"
  ],
  "type": "module",
  "scripts": {
    "prepare": "cd .. && husky",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "type-check": "vue-tsc --noEmit",
    "test:run": "vitest run",
    "lint": "eslint . --fix",
    "test:e2e": "playwright test",
    "test:e2e:integration": "playwright test --config=playwright.integration.config.ts",
    "test:e2e:showcase": "playwright test --config=playwright.showcase.config.ts",
    "test:e2e:doc-gifs": "playwright test --config=playwright.doc-gifs.config.ts",
    "check": "sh ../.husky/pre-commit.sh"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "pinia": "^3.0.4",
    "shepherd.js": "^13.0.0",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0-alpha.34",
    "@typescript-eslint/parser": "^8.0.0-alpha.34",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.1",
    "autoprefixer": "^10.4.14",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.27.0",
    "globals": "^15.14.0",
    "husky": "^9.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.0.0"
  }
}
